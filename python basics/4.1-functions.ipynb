    "num = 24\n",
    "def even_odd(num):\n",
    "    \"\"\"this function checks if a number is even or odd\"\"\"\n",
    "    if num % 2 == 0:\n",
    "        print(f\"{num} is even\")\n",
    "    else:\n",
    "        print(f\"{num} is odd\")\n",
    "\n",
    "\n",
    "even_odd(num)\n"
   ]
